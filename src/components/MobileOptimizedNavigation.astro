---
export interface Props {
  currentPath?: string;
  theme?: 'light' | 'dark';
}

const { 
  currentPath = '',
  theme = 'light'
} = Astro.props;

// Enhanced navigation structure optimized for mobile touch
const navigationItems = [
  {
    label: 'Answer Engine',
    href: '/faith-answers',
    icon: '🔬',
    description: 'Evidence-based Q&A',
    priority: 'high',
    mobileIcon: '🧠'
  },
  {
    label: 'Research',
    href: '/research',
    icon: '📊',
    description: 'Latest studies & findings',
    priority: 'medium',
    mobileIcon: '📈'
  },
  {
    label: 'Scholars',
    href: '/scholars',
    icon: '👨‍🎓',
    description: 'Expert authorities',
    priority: 'medium',
    mobileIcon: '🎓'
  },
  {
    label: 'Training',
    href: '/conversation-trainer',
    icon: '🏋️‍♂️',
    description: 'Practice apologetics',
    priority: 'high',
    mobileIcon: '💪'
  }
];
---

<header class={`mobile-nav-header mobile-nav-header--${theme}`} role="banner">
  <nav class="mobile-nav" role="navigation" aria-label="Main navigation">
    <!-- Skip Link for Accessibility -->
    <a href="#main-content" class="skip-link">Skip to main content</a>
    
    <!-- Brand/Logo -->
    <div class="nav-brand">
      <a href="/" class="brand-link" aria-label="NexusFaith Home">
        <span class="brand-icon" aria-hidden="true">✝️🔬</span>
        <span class="brand-text">NexusFaith</span>
        <span class="brand-tagline">Evidence-Based</span>
      </a>
    </div>

    <!-- Mobile Menu Toggle -->
    <button 
      class="mobile-menu-toggle"
      aria-label="Toggle navigation menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
      onclick="toggleMobileMenu(this)"
    >
      <span class="hamburger-line"></span>
      <span class="hamburger-line"></span>
      <span class="hamburger-line"></span>
      <span class="menu-label">Menu</span>
    </button>

    <!-- Desktop Navigation -->
    <ul class="desktop-nav" role="menubar">
      {navigationItems.map(item => (
        <li class="desktop-nav-item" role="none">
          <a 
            href={item.href}
            class={`desktop-nav-link ${currentPath.startsWith(item.href) ? 'desktop-nav-link--active' : ''}`}
            role="menuitem"
          >
            <span class="nav-icon" aria-hidden="true">{item.icon}</span>
            <span class="nav-text">{item.label}</span>
          </a>
        </li>
      ))}
    </ul>

    <!-- Search Button -->
    <button class="search-toggle" aria-label="Open search" onclick="openSearchModal()">
      <span class="search-icon" aria-hidden="true">🔍</span>
      <span class="search-text">Search</span>
    </button>
  </nav>

  <!-- Mobile Navigation Menu -->
  <div class="mobile-menu" id="mobile-menu" aria-hidden="true">
    <div class="mobile-menu-content">
      <!-- Quick Actions -->
      <div class="mobile-quick-actions">
        <a href="/faith-answers" class="mobile-action-btn mobile-action-btn--primary">
          <span class="action-icon">🧠</span>
          <div class="action-content">
            <span class="action-label">Get Answers</span>
            <span class="action-desc">Evidence-based Q&A</span>
          </div>
        </a>
        <button class="mobile-action-btn mobile-action-btn--secondary" onclick="openSearchModal()">
          <span class="action-icon">🔍</span>
          <div class="action-content">
            <span class="action-label">Search</span>
            <span class="action-desc">Find content</span>
          </div>
        </button>
      </div>

      <!-- Navigation Links -->
      <nav class="mobile-nav-list" role="navigation">
        <ul class="mobile-nav-items">
          {navigationItems.map(item => (
            <li class="mobile-nav-item">
              <a 
                href={item.href}
                class={`mobile-nav-link ${currentPath.startsWith(item.href) ? 'mobile-nav-link--active' : ''}`}
                onclick="closeMobileMenu()"
              >
                <div class="mobile-link-content">
                  <span class="mobile-link-icon" aria-hidden="true">{item.mobileIcon}</span>
                  <div class="mobile-link-text">
                    <span class="mobile-link-label">{item.label}</span>
                    <span class="mobile-link-desc">{item.description}</span>
                  </div>
                  <span class="mobile-link-arrow" aria-hidden="true">→</span>
                </div>
              </a>
            </li>
          ))}
        </ul>
      </nav>

      <!-- Mobile Footer -->
      <div class="mobile-menu-footer">
        <div class="mobile-footer-text">
          <strong>Evidence-based faith</strong>
          <span>for science-minded believers</span>
        </div>
      </div>
    </div>
  </div>

  <!-- Mobile Menu Backdrop -->
  <div class="mobile-menu-backdrop" onclick="closeMobileMenu()"></div>
</header>

<style>
  /* ✨ MOBILE-FIRST TOUCH-OPTIMIZED NAVIGATION */
  
  .mobile-nav-header {
    background: rgba(255, 255, 255, 0.98);
    backdrop-filter: blur(20px) saturate(180%);
    border-bottom: 1px solid rgba(0, 0, 0, 0.08);
    position: sticky;
    top: 0;
    z-index: 1000;
    transition: all 0.3s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .mobile-nav-header--dark {
    background: rgba(45, 55, 72, 0.95);
    color: white;
    border-bottom-color: rgba(255, 255, 255, 0.1);
  }

  /* Skip Link */
  .skip-link {
    position: absolute;
    top: -40px;
    left: 16px;
    background: #2b6cb0;
    color: white;
    padding: 8px 16px;
    text-decoration: none;
    border-radius: 0 0 8px 8px;
    font-size: 0.9rem;
    font-weight: 600;
    z-index: 2000;
    transition: top 0.3s ease;
  }

  .skip-link:focus {
    top: 0;
  }

  /* Main Navigation Container */
  .mobile-nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 20px;
    height: 70px;
    position: relative;
  }

  /* Brand */
  .nav-brand {
    flex-shrink: 0;
  }

  .brand-link {
    display: flex;
    align-items: center;
    gap: 8px;
    text-decoration: none;
    color: inherit;
    padding: 8px 0;
  }

  .brand-icon {
    font-size: 1.4rem;
  }

  .brand-text {
    font-size: 1.3rem;
    font-weight: 800;
    color: #2d3748;
  }

  .mobile-nav-header--dark .brand-text {
    color: white;
  }

  .brand-tagline {
    font-size: 0.7rem;
    background: linear-gradient(135deg, #3b82f6, #8b5cf6);
    color: white;
    padding: 0.2rem 0.5rem;
    border-radius: 12px;
    font-weight: 600;
    margin-left: 4px;
  }

  /* Desktop Navigation - Hidden on Mobile */
  .desktop-nav {
    display: none;
    list-style: none;
    margin: 0;
    padding: 0;
    gap: 8px;
  }

  .desktop-nav-link {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 10px 16px;
    text-decoration: none;
    color: #6b7280;
    font-weight: 500;
    border-radius: 8px;
    transition: all 0.2s ease;
    /* Minimum touch target: 44px */
    min-height: 44px;
  }

  .desktop-nav-link:hover,
  .desktop-nav-link--active {
    color: #3b82f6;
    background: rgba(59, 130, 246, 0.1);
  }

  .nav-icon {
    font-size: 1rem;
  }

  .nav-text {
    font-size: 0.9rem;
  }

  /* Search Toggle */
  .search-toggle {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 10px 14px;
    background: rgba(59, 130, 246, 0.1);
    border: 1px solid rgba(59, 130, 246, 0.2);
    border-radius: 8px;
    color: #3b82f6;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.2s ease;
    /* Touch-optimized */
    min-height: 44px;
  }

  .search-toggle:hover {
    background: rgba(59, 130, 246, 0.15);
  }

  .search-text {
    font-size: 0.9rem;
  }

  /* Mobile Menu Toggle */
  .mobile-menu-toggle {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 12px 8px;
    /* Touch-optimized minimum size */
    min-width: 44px;
    min-height: 44px;
    border-radius: 8px;
    transition: all 0.2s ease;
  }

  .mobile-menu-toggle:hover {
    background: rgba(0, 0, 0, 0.05);
  }

  .hamburger-line {
    width: 20px;
    height: 2px;
    background: #374151;
    transition: all 0.3s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    border-radius: 1px;
  }

  .mobile-nav-header--dark .hamburger-line {
    background: white;
  }

  .menu-label {
    font-size: 0.7rem;
    color: #6b7280;
    font-weight: 500;
    margin-top: 2px;
  }

  .mobile-nav-header--dark .menu-label {
    color: rgba(255, 255, 255, 0.8);
  }

  /* Hamburger Animation */
  .mobile-menu-toggle.active .hamburger-line:nth-child(1) {
    transform: rotate(45deg) translate(5px, 5px);
  }

  .mobile-menu-toggle.active .hamburger-line:nth-child(2) {
    opacity: 0;
  }

  .mobile-menu-toggle.active .hamburger-line:nth-child(3) {
    transform: rotate(-45deg) translate(7px, -6px);
  }

  /* Mobile Menu */
  .mobile-menu {
    position: fixed;
    top: 71px;
    left: 0;
    right: 0;
    bottom: 0;
    background: white;
    z-index: 999;
    transform: translateY(-100%);
    opacity: 0;
    visibility: hidden;
    transition: all 0.3s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    overflow-y: auto;
  }

  .mobile-menu.active {
    transform: translateY(0);
    opacity: 1;
    visibility: visible;
  }

  .mobile-menu-content {
    padding: 24px 20px;
    max-width: 100%;
  }

  /* Quick Actions */
  .mobile-quick-actions {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
    margin-bottom: 32px;
  }

  .mobile-action-btn {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 16px;
    border-radius: 12px;
    border: none;
    text-decoration: none;
    color: inherit;
    cursor: pointer;
    transition: all 0.3s ease;
    /* Touch-optimized */
    min-height: 60px;
  }

  .mobile-action-btn--primary {
    background: linear-gradient(135deg, #3b82f6, #8b5cf6);
    color: white;
  }

  .mobile-action-btn--primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 25px rgba(59, 130, 246, 0.25);
  }

  .mobile-action-btn--secondary {
    background: rgba(59, 130, 246, 0.1);
    color: #3b82f6;
    border: 1px solid rgba(59, 130, 246, 0.2);
  }

  .mobile-action-btn--secondary:hover {
    background: rgba(59, 130, 246, 0.15);
  }

  .action-icon {
    font-size: 1.4rem;
    flex-shrink: 0;
  }

  .action-content {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 2px;
  }

  .action-label {
    font-size: 0.9rem;
    font-weight: 600;
  }

  .action-desc {
    font-size: 0.75rem;
    opacity: 0.8;
  }

  /* Mobile Navigation List */
  .mobile-nav-items {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .mobile-nav-item {
    border-bottom: 1px solid rgba(0, 0, 0, 0.06);
  }

  .mobile-nav-item:last-child {
    border-bottom: none;
  }

  .mobile-nav-link {
    display: block;
    text-decoration: none;
    color: inherit;
    padding: 20px 0;
    transition: all 0.2s ease;
  }

  .mobile-nav-link:hover {
    background: rgba(59, 130, 246, 0.05);
    margin: 0 -20px;
    padding-left: 20px;
    padding-right: 20px;
  }

  .mobile-link-content {
    display: flex;
    align-items: center;
    gap: 16px;
    /* Touch-optimized */
    min-height: 44px;
  }

  .mobile-link-icon {
    font-size: 1.3rem;
    flex-shrink: 0;
    width: 32px;
    text-align: center;
  }

  .mobile-link-text {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .mobile-link-label {
    font-size: 1rem;
    font-weight: 600;
    color: #2d3748;
  }

  .mobile-link-desc {
    font-size: 0.85rem;
    color: #6b7280;
  }

  .mobile-link-arrow {
    color: #cbd5e0;
    font-size: 1.1rem;
    transition: all 0.2s ease;
  }

  .mobile-nav-link:hover .mobile-link-arrow {
    color: #3b82f6;
    transform: translateX(4px);
  }

  .mobile-nav-link--active .mobile-link-label {
    color: #3b82f6;
  }

  .mobile-nav-link--active .mobile-link-arrow {
    color: #3b82f6;
  }

  /* Mobile Menu Footer */
  .mobile-menu-footer {
    margin-top: 32px;
    padding: 24px;
    background: rgba(59, 130, 246, 0.05);
    border-radius: 12px;
    text-align: center;
  }

  .mobile-footer-text {
    display: flex;
    flex-direction: column;
    gap: 4px;
    font-size: 0.9rem;
    color: #4a5568;
  }

  .mobile-footer-text strong {
    color: #3b82f6;
  }

  /* Backdrop */
  .mobile-menu-backdrop {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(0, 0, 0, 0.3);
    backdrop-filter: blur(4px);
    z-index: 998;
    opacity: 0;
    visibility: hidden;
    transition: all 0.3s ease;
  }

  .mobile-menu.active ~ .mobile-menu-backdrop {
    opacity: 1;
    visibility: visible;
  }

  /* Tablet and Desktop Styles */
  @media (min-width: 768px) {
    .mobile-nav {
      height: 80px;
      padding: 0 32px;
    }

    .desktop-nav {
      display: flex;
    }

    .mobile-menu-toggle {
      display: none;
    }

    .search-text {
      display: inline;
    }

    /* Desktop hover states */
    .desktop-nav-link {
      position: relative;
    }

    .desktop-nav-link::after {
      content: '';
      position: absolute;
      bottom: -2px;
      left: 50%;
      width: 0;
      height: 2px;
      background: linear-gradient(90deg, #3b82f6, #8b5cf6);
      transition: all 0.3s ease;
      transform: translateX(-50%);
    }

    .desktop-nav-link--active::after,
    .desktop-nav-link:hover::after {
      width: 80%;
    }
  }

  /* Large Desktop */
  @media (min-width: 1024px) {
    .mobile-nav {
      padding: 0 48px;
      max-width: 1200px;
      margin: 0 auto;
    }

    .brand-text {
      font-size: 1.4rem;
    }

    .desktop-nav {
      gap: 12px;
    }

    .desktop-nav-link {
      padding: 12px 20px;
    }

    .nav-text {
      font-size: 1rem;
    }
  }

  /* High-DPI and Touch Optimization */
  @media (hover: none) and (pointer: coarse) {
    /* Touch devices */
    .mobile-nav-link,
    .mobile-action-btn,
    .search-toggle,
    .mobile-menu-toggle {
      min-height: 48px; /* Larger touch targets */
    }

    .mobile-action-btn {
      min-height: 64px;
    }

    /* Remove hover states on touch devices */
    .mobile-nav-link:hover {
      background: none;
      margin: 0;
      padding: 20px 0;
    }
  }
</style>

<script>
  // Mobile Menu Controls
  function toggleMobileMenu(button) {
    const mobileMenu = document.getElementById('mobile-menu');
    const isOpen = button.getAttribute('aria-expanded') === 'true';
    
    button.setAttribute('aria-expanded', !isOpen);
    button.classList.toggle('active');
    mobileMenu.classList.toggle('active');
    mobileMenu.setAttribute('aria-hidden', isOpen);
    
    // Prevent body scrolling when menu is open
    document.body.style.overflow = isOpen ? 'auto' : 'hidden';
  }

  function closeMobileMenu() {
    const button = document.querySelector('.mobile-menu-toggle');
    const mobileMenu = document.getElementById('mobile-menu');
    
    button.setAttribute('aria-expanded', 'false');
    button.classList.remove('active');
    mobileMenu.classList.remove('active');
    mobileMenu.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = 'auto';
  }

  function openSearchModal() {
    // Placeholder for search modal functionality
    console.log('Opening search modal...');
    // TODO: Implement search modal
  }

  // Close mobile menu on resize to desktop
  window.addEventListener('resize', () => {
    if (window.innerWidth >= 768) {
      closeMobileMenu();
    }
  });

  // Keyboard navigation
  document.addEventListener('keydown', (e) => {
    const mobileMenu = document.getElementById('mobile-menu');
    const isMenuOpen = mobileMenu.classList.contains('active');
    
    if (e.key === 'Escape' && isMenuOpen) {
      closeMobileMenu();
    }
  });
</script>